{
  "name": "holocron-research",
  "version": "1.0.7",
  "description": "Holocron CLI — start the local AI research platform with one command",
  "license": "PolyForm-Noncommercial-1.0.0",
  "author": "Holocron Contributors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hatif03/holocron.git"
  },
  "homepage": "https://github.com/hatif03/holocron#readme",
  "bugs": {
    "url": "https://github.com/hatif03/holocron/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "holocron": "dist/index.js"
  },
  "files": [
    "dist",
    "assets",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs --dts --clean",
    "dev": "tsup src/index.ts --format cjs --watch",
    "test": "vitest run",
    "prepublishOnly": "node ../../scripts/copy-cli-migrations.mjs && npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "holocron",
    "research",
    "ai-agents",
    "latex",
    "academic",
    "k2-think",
    "byok",
    "local-first"
  ],
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^14.0.0",
    "ora": "^8.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
