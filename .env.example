# LLM provider: k2think | groq | openai | anthropic | google | openrouter | custom
LLM_PROVIDER=k2think
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=

# K2 Think (default — request at https://build.k2think.ai/)
K2THINK_API_KEY=mock-key-for-dev
K2THINK_BASE_URL=https://api.k2think.ai/v1/chat/completions
K2THINK_MODEL=MBZUAI-IFM/K2-Think-v2

# Other providers (BYOK — set the one you use)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=

# Semantic Scholar (optional)
SEMANTIC_SCHOLAR_API_KEY=

# Database
DATABASE_URL=postgresql://holocron:holocron@localhost:5432/holocron

# Storage (repo root; Docker agents use bind mount to same folder)
STORAGE_PATH=./storage

# Auth mode: local | supabase
AUTH_MODE=local

# Agent service
AGENTS_SERVICE_URL=http://localhost:8000
NEXT_PUBLIC_AGENTS_URL=http://localhost:8000

# LaTeX compile service
LATEX_SERVICE_URL=http://localhost:8081

# Supermemory Local (hackathon)
SUPERMEMORY_API_URL=http://localhost:6767
SUPERMEMORY_API_KEY=

# For local Next.js dev, copy SUPERMEMORY_* into apps/web/.env and set:
# STORAGE_PATH=../../storage
