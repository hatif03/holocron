# K2 Think (required — request at https://build.k2think.ai/)
K2THINK_API_KEY=mock-key-for-dev
K2THINK_BASE_URL=https://www.k2think.ai/api/chat/completions
K2THINK_MODEL=MBZUAI-IFM/K2-Think-v2

# Semantic Scholar (optional)
SEMANTIC_SCHOLAR_API_KEY=

# Database
DATABASE_URL=postgresql://holocron:holocron@localhost:5432/holocron

# Storage
STORAGE_PATH=./storage

# Auth mode: local | supabase
AUTH_MODE=local

# Agent service
AGENTS_SERVICE_URL=http://localhost:8000
NEXT_PUBLIC_AGENTS_URL=http://localhost:8000

# LaTeX compile service
LATEX_SERVICE_URL=http://localhost:8081
